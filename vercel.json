{
    "version": 2,
    "env": {
        "VERCEL_FORCE_PROD_SYNC": "v3.16-final"
    },
    "builds": [
        {
            "src": "vercel_wsgi.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "15mb",
                "runtime": "python3.12"
            }
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/static/$1"
        },
        {
            "src": "/(.*)",
            "dest": "vercel_wsgi.py"
        }
    ]
}